# XUBand Environment Variables
# Copy to .env for local, set as Railway env vars for production

# Database (Railway MySQL plugin auto-injects these)
MYSQLHOST=localhost
MYSQLPORT=3306
MYSQLDATABASE=xuband
MYSQLUSER=root
MYSQLPASSWORD=your_password_here

# App
APP_URL=http://localhost
APP_SECRET=change_this_to_a_random_secret_string
